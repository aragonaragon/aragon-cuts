{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Shorts Maker",
  "version": "0.1.0",
  "identifier": "com.aragon.shortsmaker",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Shorts Maker",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 700,
        "decorations": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "publisher": "aragon",
    "copyright": "Copyright (c) 2026 aragon",
    "category": "Video",
    "shortDescription": "Convert videos to vertical 9:16 shorts",
    "longDescription": "Drop a video, pick IN/OUT, click encode. Produces vertical 9:16 clips ready for YouTube Shorts, TikTok, Reels, and Twitch.",
    "externalBin": [
      "binaries/ffmpeg",
      "binaries/ffprobe"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "offlineInstaller"
      }
    }
  }
}
