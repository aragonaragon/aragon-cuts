# Supply-chain hardening
# امنع تنفيذ سكربتات التثبيت (install/postinstall) — أقوى دفاع ضد الحزم الخبيثة.
ignore-scripts=true
# ثبّت النسخ بدقة (بدون ^ أو ~) حتى لا تتسلل ترقية غير متوقعة.
save-exact=true

# اختياري: ارفض الحزم المنشورة خلال آخر N أيام (دفاع ضد الإصدارات المخترَقة حديثاً).
# معطّل لأنه يكسر `npm install` و`npm audit` على npm 11.13.x ("Invalid time value").
# فعّله بعد الترقية إلى نسخة npm تدعمه بشكل سليم:
# min-release-age=7d
