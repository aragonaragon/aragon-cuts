*.msi
*.exe
!scripts/*.exe

# OS junk
Thumbs.db
ehthumbs.db
desktop.ini

# Temp / cache
tmp/
.cache/

# === Security hardening (added 2026-05-20) ===
# Catch-all for env files; allow only examples through
.env*
!.env.example
!.env.sample
!.env.template

